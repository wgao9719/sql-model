# Copy to .env and fill in actual values. .env is gitignored.
#   cp .env.example .env && $EDITOR .env

# ---- Weights & Biases ----
# Grab from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=bird_sql_sft
# Optional: wandb team/org; omit for personal account.
# WANDB_ENTITY=

# ---- Hugging Face ----
# Only needed if you download gated models. Qwen3-Coder is public — leave blank.
# HF_TOKEN=
HF_HOME=/net/holy-isilon/ifs/rc_labs/ydu_lab/will/hf_cache

# ---- Modal ----
# Modal uses its own auth (~/.modal.toml from `modal setup`) and injects secrets
# from `modal secret create wandb WANDB_API_KEY=...` — these env vars are only
# for the Cannon path's shell scripts.
